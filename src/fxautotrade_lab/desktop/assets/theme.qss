/* ============================================================================
   FXAutoTrade Lab — theme.qss
   Load: QApplication.instance().setStyleSheet(load_theme_qss())
   ============================================================================ */

/* ---------- Base ---------- */
QMainWindow, QWidget {
    background: #f7f8fa;
    color: #0f172a;
    font-family: "Inter", "Helvetica Neue", "Hiragino Sans", "Yu Gothic UI", sans-serif;
    font-size: 13px;
}
QLabel { border: none; background: transparent; color: #0f172a; }
QLabel[role="muted"]     { color: #475569; }
QLabel[role="muted2"]    { color: #64748b; }
QLabel[role="h1"]        { font-size: 22px; font-weight: 700; letter-spacing: -0.01em; }
QLabel[role="h2"]        { font-size: 13.5px; font-weight: 700; color: #0f172a; }
QLabel[role="eyebrow"]   { color: #64748b; font-size: 11px; font-weight: 600;
                           letter-spacing: 0.08em; text-transform: uppercase; }
QLabel[role="kpi-value"] { font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
                           font-size: 28px; font-weight: 600; color: #0f172a; }
QLabel[role="kpi-value"][variant="code-md"] {
    font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
    font-size: 16px; font-weight: 600;
}
QLabel[role="kpi-value"][variant="mono-md"] {
    font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
    font-size: 18px; font-weight: 600;
}
QLabel[role="kpi-value"][variant="plain"] {
    font-family: "Inter", "Helvetica Neue", "Hiragino Sans", "Yu Gothic UI", sans-serif;
    font-size: 18px; font-weight: 600;
    color: #0f172a;
}
QLabel[role="kpi-note"]  { color: #64748b; font-size: 11.5px; }
QLabel[role="kpi-trend"] {
    font-size: 11.5px; font-weight: 600; color: #475569;
}
QLabel[role="kpi-trend"][tone="pos"] { color: #0f766e; }
QLabel[role="kpi-trend"][tone="neg"] { color: #b91c1c; }
QLabel[role="mono"]      { font-family: "JetBrains Mono", "SF Mono", Menlo, monospace; }
QLabel[role="mono-hint"] {
    font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
    color: #64748b;
    font-size: 11.5px;
}
QLabel[role="detail-value"] {
    font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
    font-size: 13px; font-weight: 600; color: #0f172a;
}
QLabel[role="detail-value"][variant="text"] {
    font-family: "Inter", "Helvetica Neue", "Hiragino Sans", "Yu Gothic UI", sans-serif;
    font-weight: 400;
    color: #334155;
}
QLabel[role="detail-value"][size="sm"] { font-size: 12.5px; }
QLabel[role="help-body"] { color: #334155; font-size: 13px; }
QLabel[role="section-caption"] {
    color: #64748b;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
}
QLabel[role="form-label"] {
    color: #334155;
    font-size: 12.5px;
    font-weight: 500;
}
QLabel[role="detail-label"] {
    color: #64748b;
    font-size: 11.5px;
}
QLabel[role="h2"][variant="mono-sm"] {
    font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
    font-size: 12.5px;
    font-weight: 600;
}
QLabel[role="breadcrumb"]        { color: #475569; font-size: 12.5px; }
QLabel[role="breadcrumb-current"]{ color: #0f172a; font-weight: 600; font-size: 12.5px; }
QLabel[tone="pos"]       { color: #0f766e; }
QLabel[tone="neg"]       { color: #b91c1c; }
QLabel[tone="warn"]      { color: #92400e; }
QLabel[tone="info"]      { color: #1e40af; }

/* Form labels inside QFormLayout — one canonical tone */
QFormLayout QLabel {
    color: #334155;
    font-size: 12.5px;
    font-weight: 500;
    padding-right: 8px;
}
QFormLayout QLabel[role="muted"]  { color: #475569; font-weight: 400; }
QFormLayout QLabel[role="muted2"] { color: #64748b; font-weight: 400; }

/* ---------- Sidebar ---------- */
QListWidget#navSidebar {
    background: #0f1f36;
    color: #cbd6e4;
    border: none;
    padding: 16px 10px;
    outline: 0;
    font-size: 13px;
}
QListWidget#navSidebar::item {
    padding: 9px 12px 9px 12px;
    border-radius: 8px;
    margin: 1px 4px;
    color: #cbd6e4;
}
QListWidget#navSidebar::item:hover    { background: rgba(255,255,255,0.04); color: #ffffff; }
QListWidget#navSidebar::item:selected {
    background: rgba(20,184,166,0.14);
    color: #ffffff;
    border-left: 3px solid #14b8a6;
    padding-left: 9px;
}

/* ---------- Topbar ---------- */
QToolBar#topBar {
    background: #ffffff;
    border: none;
    border-bottom: 1px solid #e6e8ee;
    spacing: 8px;
    padding: 8px 16px;
    min-height: 48px;
}

/* ---------- Status bar ---------- */
QStatusBar {
    background: #ffffff;
    color: #475569;
    border-top: 1px solid #e6e8ee;
    font-size: 11.5px;
    padding: 2px 16px;
    min-height: 26px;
}
QStatusBar QLabel { color: #475569; }
QStatusBar QLabel[tone="pos"]  { color: #0f766e; font-weight: 600; }
QStatusBar QLabel[tone="neg"]  { color: #b91c1c; font-weight: 600; }
QStatusBar QLabel[role="mono"] { font-family: "JetBrains Mono", monospace; color: #0f172a; }

/* ---------- Card ---------- */
QFrame[card="true"] {
    background: #ffffff;
    border: 1px solid #e6e8ee;
    border-radius: 10px;
}
QFrame[card="sunken"] {
    background: #f1f3f7;
    border: 1px solid #eff1f5;
    border-radius: 8px;
}
QFrame[card="true"] > QWidget#cardHead {
    border-bottom: 1px solid #e6e8ee;
}

/* ---------- Buttons ---------- */
QPushButton {
    background: #ffffff;
    color: #0f172a;
    border: 1px solid #e6e8ee;
    border-radius: 6px;
    padding: 6px 12px;
    min-height: 28px;
    font-size: 12.5px;
    font-weight: 500;
}
QPushButton:hover:enabled  { background: #f1f3f7; }
QPushButton:pressed        { background: #e6e8ee; }
QPushButton:focus          { border: 1px solid #14b8a6; }
QPushButton:disabled       { color: #94a3b8; background: #f7f8fa; }

QPushButton[variant="primary"] {
    background: #14b8a6; color: #ffffff; border-color: #14b8a6; font-weight: 600;
}
QPushButton[variant="primary"]:hover:enabled { background: #0ea597; border-color: #0ea597; }
QPushButton[variant="primary"]:pressed       { background: #0c8f82; }
QPushButton[variant="primary"]:disabled      { background: #9adcd3; border-color: #9adcd3; color: #ffffff; }

QPushButton[variant="danger"] {
    background: #ffffff; color: #b91c1c; border-color: #f3c7c7;
}
QPushButton[variant="danger"]:hover:enabled  { background: #fff1f1; }

QPushButton[variant="ghost"] {
    background: transparent; border-color: transparent; color: #475569; padding: 4px 10px;
}
QPushButton[variant="ghost"]:hover:enabled   { background: #f1f3f7; color: #0f172a; }

QPushButton[variant="kill"] {
    background: #ffffff; color: #b91c1c; border: 1px solid #f3c7c7; font-weight: 700;
}
QPushButton[variant="kill"]:hover:enabled    { background: #fdecec; }

QPushButton[variant="success"] {
    background: #ffffff; color: #0f766e; border-color: #b7dcd6; font-weight: 600;
}
QPushButton[variant="success"]:hover:enabled { background: #ecfdf5; }

/* Back-compat: legacy `role` property values from ui_controls.py */
QPushButton[role="primary"] {
    background: #14b8a6; color: #ffffff; border-color: #14b8a6; font-weight: 600;
}
QPushButton[role="primary"]:hover:enabled { background: #0ea597; border-color: #0ea597; }
QPushButton[role="primary"]:disabled      { background: #9adcd3; border-color: #9adcd3; color: #ffffff; }
QPushButton[role="secondary"] {
    background: #ffffff; color: #0f172a; border-color: #cbd5e1;
}
QPushButton[role="secondary"]:hover:enabled { background: #f1f3f7; }
QPushButton[role="success"] {
    background: #ffffff; color: #0f766e; border-color: #b7dcd6; font-weight: 600;
}
QPushButton[role="success"]:hover:enabled { background: #ecfdf5; }
QPushButton[role="danger"] {
    background: #ffffff; color: #b91c1c; border-color: #f3c7c7; font-weight: 600;
}
QPushButton[role="danger"]:hover:enabled  { background: #fff1f1; }
QPushButton[role="neutral"] {
    background: transparent; border-color: transparent; color: #475569;
}
QPushButton[role="neutral"]:hover:enabled { background: #f1f3f7; color: #0f172a; }

/* ---------- Segmented control ---------- */
QPushButton[variant="seg"] {
    background: transparent;
    border: 1px solid transparent;
    border-radius: 4px;
    padding: 4px 10px;
    min-height: 22px;
    font-size: 12px;
    color: #475569;
    font-weight: 500;
}
QPushButton[variant="seg"]:hover:enabled   { color: #0f172a; }
QPushButton[variant="seg"]:checked         { background: #ffffff; color: #0f172a;
                                              border: 1px solid #e6e8ee; font-weight: 600; }
QFrame[role="segmented"] { background: #f1f3f7; border-radius: 6px; padding: 2px; }

/* ---------- Inputs ---------- */
QLineEdit, QComboBox, QDateEdit, QSpinBox, QDoubleSpinBox, QPlainTextEdit, QTextEdit, QTextBrowser {
    background: #ffffff;
    border: 1px solid #e6e8ee;
    border-radius: 6px;
    padding: 6px 10px;
    color: #0f172a;
    selection-background-color: rgba(20,184,166,0.18);
    selection-color: #0f172a;
    min-height: 26px;
    font-size: 12.5px;
}
QLineEdit:focus, QComboBox:focus, QDateEdit:focus,
QSpinBox:focus, QDoubleSpinBox:focus,
QPlainTextEdit:focus, QTextEdit:focus {
    border: 1px solid #14b8a6;
}
QLineEdit[align="num"], QSpinBox, QDoubleSpinBox {
    font-family: "JetBrains Mono", monospace;
}
QLineEdit:read-only { background: #f7f8fa; color: #475569; }

QComboBox::drop-down {
    border: none;
    width: 24px;
    subcontrol-position: center right;
    padding-right: 6px;
}
QDateEdit::drop-down {
    background: #f8fafc;
    border: none;
    border-left: 1px solid #e6e8ee;
    border-top-right-radius: 6px;
    border-bottom-right-radius: 6px;
    width: 30px;
    subcontrol-origin: padding;
    subcontrol-position: top right;
}
QComboBox::down-arrow {
    image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='10' height='6' viewBox='0 0 10 6'><path d='M1 1l4 4 4-4' fill='none' stroke='%23475569' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/></svg>");
    width: 10px; height: 6px;
}
QDateEdit::down-arrow {
    image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 14 14'><rect x='2' y='3' width='10' height='9' rx='1.5' fill='none' stroke='%23475569' stroke-width='1.2'/><path d='M4 2v3M10 2v3M2.5 5.5h9' fill='none' stroke='%23475569' stroke-width='1.2' stroke-linecap='round'/></svg>");
    width: 14px; height: 14px;
}
QDateEdit::drop-down:hover {
    background: #eefaf8;
}
QDateEdit::drop-down:pressed {
    background: #dff6f2;
}
QComboBox:on { border-color: #14b8a6; }
QComboBox QAbstractItemView {
    background: #ffffff; border: 1px solid #e6e8ee; border-radius: 6px;
    selection-background-color: rgba(20,184,166,0.12); selection-color: #0f172a;
    padding: 4px;
}
QCalendarWidget QWidget#qt_calendar_navigationbar {
    background: #ffffff;
    border-bottom: 1px solid #e6e8ee;
    min-height: 34px;
}
QCalendarWidget QToolButton {
    background: transparent;
    border: none;
    color: #0f172a;
    font-size: 12.5px;
    font-weight: 600;
    min-width: 36px;
    min-height: 28px;
    padding: 4px 8px;
}
QCalendarWidget QToolButton:hover {
    background: #f1f3f7;
    border-radius: 6px;
}
QCalendarWidget QToolButton#qt_calendar_monthbutton {
    min-width: 96px;
}
QCalendarWidget QSpinBox {
    min-width: 72px;
    padding: 2px 6px;
}
QCalendarWidget QTableView,
QCalendarWidget QTableWidget {
    background: #ffffff;
    alternate-background-color: #ffffff;
    border: none;
    gridline-color: transparent;
    selection-background-color: rgba(20,184,166,0.10);
    selection-color: #0f172a;
    outline: 0;
}
QCalendarWidget QTableView::item,
QCalendarWidget QTableWidget::item {
    padding: 0px;
    margin: 0px;
    border: none;
}
QCalendarWidget QHeaderView::section {
    background: transparent;
    color: #64748b;
    border: none;
    padding: 4px 0;
    font-size: 11px;
    font-weight: 600;
}

QCheckBox { spacing: 6px; color: #0f172a; font-size: 12.5px; }
QCheckBox::indicator {
    width: 14px; height: 14px;
    border: 1.5px solid #cbd5e1; border-radius: 3px; background: #ffffff;
}
QCheckBox::indicator:hover   { border-color: #14b8a6; }
QCheckBox::indicator:checked {
    background: #14b8a6; border-color: #14b8a6;
    image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='10' height='10' viewBox='0 0 10 10'><path d='M2 5l2 2 4-4' fill='none' stroke='white' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'/></svg>");
}
QCheckBox::indicator:disabled { background: #f1f3f7; border-color: #e6e8ee; }
QCheckBox:disabled            { color: #94a3b8; }

QRadioButton::indicator { width: 14px; height: 14px; border-radius: 7px;
                          border: 1.5px solid #cbd5e1; background: #ffffff; }
QRadioButton::indicator:checked { background: #14b8a6; border-color: #14b8a6; }

/* ---------- Tables ---------- */
QTableView, QTableWidget {
    background: #ffffff;
    alternate-background-color: #ffffff;
    border: none;
    gridline-color: transparent;
    selection-background-color: rgba(20,184,166,0.10);
    selection-color: #0f172a;
    font-size: 12.5px;
}
QTableView::item, QTableWidget::item {
    padding: 10px 12px;
    border-bottom: 1px solid #eff1f5;
}
QTableView::item:selected, QTableWidget::item:selected {
    background: rgba(20,184,166,0.10);
    color: #0f172a;
    border-left: 2px solid #14b8a6;
    padding-left: 10px;
}
QHeaderView::section {
    background: #f7f8fa;
    color: #64748b;
    border: none;
    border-bottom: 1px solid #e6e8ee;
    padding: 10px 12px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.02em;
}
QHeaderView::section:last { border-right: none; }

/* ---------- Chips ---------- */
QLabel#chip_neutral, QLabel#chip_running, QLabel#chip_paper,
QLabel#chip_warn, QLabel#chip_neg, QLabel#chip_info {
    padding: 2px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    border: 1px solid #e6e8ee;
    background: #f7f8fa;
    color: #475569;
}
QLabel#chip_running { background: rgba(15,118,110,0.10); color: #0f766e;
                      border-color: rgba(15,118,110,0.20); }
QLabel#chip_paper   { background: rgba(30,64,175,0.08);  color: #1e40af;
                      border-color: rgba(30,64,175,0.20); }
QLabel#chip_warn    { background: rgba(146,64,14,0.10);  color: #92400e;
                      border-color: rgba(146,64,14,0.20); }
QLabel#chip_neg     { background: rgba(185,28,28,0.10);  color: #b91c1c;
                      border-color: rgba(185,28,28,0.20); }
QLabel#chip_info    { background: rgba(20,184,166,0.10); color: #14b8a6;
                      border-color: rgba(20,184,166,0.20); }

/* ---------- Dock ---------- */
QDockWidget#logDock {
    background: #ffffff;
    border-top: 1px solid #e6e8ee;
    font-size: 12px;
    color: #475569;
}
QDockWidget#logDock::title {
    background: #ffffff;
    padding: 6px 12px;
    border-top: 1px solid #e6e8ee;
    border-bottom: 1px solid #e6e8ee;
    text-align: left;
    font-weight: 600;
}
QTextEdit#logOutput {
    background: #ffffff;
    border: none;
    color: #0f172a;
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    padding: 10px 14px;
}

/* ---------- Native QtCharts view ---------- */
QLabel#nativeChartStatus {
    padding: 6px 2px 2px 2px;
    font-size: 13px;
}
QChartView#nativeChartView {
    background: #ffffff;
    border: 1px solid #e6e8ee;
    border-radius: 10px;
}

/* ---------- ScrollBar ---------- */
QScrollBar:vertical   { background: transparent; width: 10px; margin: 2px; }
QScrollBar:horizontal { background: transparent; height: 10px; margin: 2px; }
QScrollBar::handle:vertical, QScrollBar::handle:horizontal {
    background: #d6dbe3;
    border-radius: 4px;
    min-height: 28px;
    min-width: 28px;
}
QScrollBar::handle:hover   { background: #9aa4b2; }
QScrollBar::handle:pressed { background: #64748b; }
QScrollBar::add-line, QScrollBar::sub-line { width: 0; height: 0; background: none; border: none; }
QScrollBar::add-page, QScrollBar::sub-page { background: none; }

/* ---------- Splitter ---------- */
QSplitter::handle            { background: #e6e8ee; }
QSplitter::handle:horizontal { width: 1px; }
QSplitter::handle:vertical   { height: 1px; }

/* ---------- Tabs ---------- */
QTabWidget::pane { border: 1px solid #e6e8ee; border-radius: 10px; top: -1px; }
QTabBar::tab {
    background: transparent; color: #475569;
    padding: 8px 14px; margin-right: 2px;
    border: 1px solid transparent; border-bottom: none;
    border-top-left-radius: 6px; border-top-right-radius: 6px;
    font-size: 12.5px; font-weight: 500;
}
QTabBar::tab:hover    { color: #0f172a; }
QTabBar::tab:selected { background: #ffffff; color: #0f172a; font-weight: 600;
                         border-color: #e6e8ee; }

/* ---------- Progress ---------- */
QProgressBar {
    background: #f1f3f7; border: none; border-radius: 4px;
    height: 6px; text-align: center; color: transparent;
}
QProgressBar::chunk { background: #14b8a6; border-radius: 4px; }

/* ---------- Tooltip ---------- */
QToolTip {
    background: #0f172a; color: #ffffff; padding: 4px 8px;
    border: none; border-radius: 4px; font-size: 11.5px;
}

/* ---------- Banner ---------- */
QFrame#banner {
    background: rgba(20,184,166,0.06);
    border: 1px solid rgba(20,184,166,0.20);
    border-radius: 8px;
}
QFrame#banner[tone="warn"] {
    background: rgba(146,64,14,0.06);
    border-color: rgba(146,64,14,0.20);
}
QLabel#bannerIcon {
    color: #14b8a6;
    font-size: 14px;
    font-weight: 700;
    min-width: 18px;
}
QFrame#banner[tone="warn"] QLabel#bannerIcon { color: #92400e; }
QFrame#banner QLabel[role="muted"] { color: #0f172a; }

/* ---------- Symbol chip (in ChipField) ---------- */
QFrame#chip_symbol {
    background: #ffffff;
    border: 1px solid #e6e8ee;
    border-radius: 999px;
    min-height: 24px;
    max-height: 28px;
}
QFrame#chip_symbol QLabel {
    font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
    font-size: 12px;
    color: #0f172a;
}
QPushButton#chipRemove {
    background: transparent;
    border: none;
    color: #64748b;
    font-size: 11px;
    padding: 0;
    min-height: 0;
    min-width: 0;
}
QPushButton#chipRemove:hover { color: #b91c1c; }

/* ---------- Suffix input ---------- */
QFrame#suffixInput {
    background: #ffffff;
    border: 1px solid #e6e8ee;
    border-radius: 6px;
    min-height: 28px;
    max-height: 32px;
}
QFrame#suffixInput:focus-within { border-color: #14b8a6; }
QFrame#suffixInput QLineEdit {
    background: transparent;
    border: none;
    padding: 0;
    min-height: 0;
    color: #0f172a;
    font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
}
QFrame#suffixInput QLabel {
    color: #64748b;
    font-size: 11.5px;
}

/* ---------- YAML pre ---------- */
QPlainTextEdit[role="yaml-pre"] {
    background: #f7f8fa;
    border: 1px solid #e6e8ee;
    border-radius: 10px;
    padding: 14px;
    font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
    font-size: 12px;
    color: #334155;
}

/* ---------- Log dock-like view ---------- */
QTextBrowser[role="logdock"] {
    background: #ffffff;
    border: 1px solid #e6e8ee;
    border-radius: 8px;
    font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
    font-size: 12px;
    color: #0f172a;
    padding: 10px 14px;
}

/* ---------- Automation log dock (navy) ---------- */
QFrame[role="logdock-dark"] {
    background: #0b1020;
    border-radius: 12px;
    color: #e2e8f0;
}
QFrame[role="logdock-dark"] QLabel[role="h2-sm"] {
    color: #f1f5f9; font-size: 12.5px; font-weight: 600;
}
QTextBrowser[role="logdock-body"] {
    background: transparent;
    border: none;
    color: #e2e8f0;
    font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
    font-size: 12px;
    padding: 0;
}

/* ---------- Counted tabs ---------- */
QPushButton[role="tab"] {
    background: transparent;
    border: none;
    padding: 10px 14px;
    color: #64748b;
    font-size: 13px;
    font-weight: 500;
    border-bottom: 2px solid transparent;
    min-height: 0;
}
QPushButton[role="tab"]:hover    { color: #0f172a; }
QPushButton[role="tab"]:checked  { color: #0f172a; border-bottom-color: #14b8a6; }

/* ============================================================================
   Application shell: Sidebar / Topbar / StatusBar / LogDock
   ============================================================================ */

/* ---------- Sidebar ---------- */
/* Catch-all: prevent the base QWidget bg (#f7f8fa) from bleeding through to
   the scroll viewport / NavBody / brand container etc. and also give sidebar
   labels a sane default color that overrides the base QLabel rule. */
QWidget#Sidebar,
QWidget#Sidebar > QWidget,
QWidget#Sidebar QWidget {
    background: transparent;
}
QWidget#Sidebar QLabel { color: #d9dee8; }

QWidget#Sidebar {
    background: #0f172a;
    border-right: 1px solid #e5e8ee;
}
QWidget#NavBody { background: transparent; }

/* --- Brand --- */
QWidget#Brand {
    background: transparent;
    border-bottom: 1px solid rgba(255,255,255,0.04);
}
QWidget#Sidebar QLabel#BrandMark {
    background: #0f766e;
    color: #ffffff;
    font: 700 12px "JetBrains Mono", "Menlo", monospace;
    border-radius: 7px;
    padding: 0;
    qproperty-alignment: AlignCenter;
}
QWidget#Sidebar QLabel#BrandT1 {
    color: #ffffff;
    background: transparent;
    font: 600 13px "Inter", "Noto Sans JP", sans-serif;
}
QWidget#Sidebar QLabel#BrandT2 {
    color: #8591a6;
    background: transparent;
    font: 500 10px "Inter", sans-serif;
    letter-spacing: 1.2px;
}

/* --- Nav scroll --- */
QWidget#Sidebar QScrollArea {
    background: transparent;
    border: none;
}
QWidget#Sidebar QScrollArea > QWidget > QWidget { background: transparent; }
QWidget#Sidebar QScrollBar:vertical {
    background: transparent;
    width: 6px;
    margin: 0;
}
QWidget#Sidebar QScrollBar::handle:vertical {
    background: rgba(255,255,255,0.08);
    border-radius: 3px;
    min-height: 24px;
}
QWidget#Sidebar QScrollBar::handle:vertical:hover { background: rgba(255,255,255,0.16); }
QWidget#Sidebar QScrollBar::add-line:vertical,
QWidget#Sidebar QScrollBar::sub-line:vertical { height: 0; background: none; }
QWidget#Sidebar QScrollBar::add-page:vertical,
QWidget#Sidebar QScrollBar::sub-page:vertical { background: none; }

/* --- Nav section header --- */
QWidget#Sidebar QLabel#NavSection {
    color: #8591a6;
    background: transparent;
    font: 600 10px "Inter", sans-serif;
    letter-spacing: 1.5px;
    padding: 14px 10px 6px 10px;
    text-transform: uppercase;
}

/* --- Nav item (unselected) --- */
QWidget#NavItem {
    background: transparent;
    border: none;
    border-left: 3px solid transparent;
    border-radius: 8px;
    margin: 1px 4px;
}
QWidget#NavItem:hover { background: #1b2740; }
QLabel#NavText {
    color: #d9dee8;
    background: transparent;
    font: 500 13px "Inter", "Noto Sans JP", sans-serif;
}
QLabel#NavIcon { background: transparent; qproperty-alignment: AlignCenter; }

/* --- Nav item (active) --- */
QWidget#NavItem[active="true"] {
    background: #2a3a5c;
    border-left: 3px solid #0f766e;
    border-radius: 8px;
}
QWidget#NavItem[active="true"] QLabel#NavText {
    color: #ffffff;
    font-weight: 600;
}

/* --- Badge (数字 pill) --- */
QWidget#Sidebar QLabel#NavBadge {
    background: rgba(255,255,255,0.08);
    color: #d9dee8;
    font: 500 10px "JetBrains Mono", "Menlo", monospace;
    padding: 2px 6px;
    border-radius: 9px;
    min-width: 14px;
    qproperty-alignment: AlignCenter;
}
QWidget#NavItem[active="true"] QLabel#NavBadge {
    background: rgba(255,255,255,0.16);
    color: #ffffff;
}

/* --- Running dot (緑) --- */
QWidget#Sidebar QLabel#NavDot {
    background: #22c993;
    border-radius: 3px;
}

/* --- Footer --- */
QWidget#SidebarFooter {
    background: transparent;
    border-top: 1px solid rgba(255,255,255,0.05);
}
QWidget#Sidebar QLabel#FooterVer {
    color: #8591a6;
    background: transparent;
    font: 400 11px "JetBrains Mono", "Menlo", monospace;
}
QWidget#Sidebar QLabel#FooterPill {
    background: rgba(34,201,147,0.14);
    color: #6fd2a3;
    padding: 3px 9px;
    border-radius: 9px;
    font: 500 11px "Inter", "Noto Sans JP", sans-serif;
    qproperty-alignment: AlignCenter;
}
QWidget#Sidebar QLabel#FooterPill[state="err"] {
    background: rgba(181,52,31,0.18);
    color: #f1a090;
}

/* ---------- Topbar ---------- */
QWidget#Topbar { background: #ffffff; border-bottom: 1px solid #e5e8ee; }
QLabel#CrumbSection {
    color: #4a5568; background: transparent;
    font-family: "Inter", "Helvetica Neue", "Hiragino Sans", "Yu Gothic UI", sans-serif;
    font-size: 13px; font-weight: 500;
}
QLabel#CrumbSep {
    color: #6b7587; background: transparent;
    font-size: 13px; font-weight: 500;
}
QLabel#CrumbNow {
    color: #0f172a; background: transparent;
    font-family: "Inter", "Helvetica Neue", "Hiragino Sans", "Yu Gothic UI", sans-serif;
    font-size: 13px; font-weight: 600;
}

QPushButton#TbSearch {
    background: #eef0f3;
    border: 1px solid #e5e8ee;
    border-radius: 8px;
    text-align: left;
    padding: 0;
    min-height: 0;
}
QPushButton#TbSearch:hover { background: #e6e9ef; }
QLabel#TbSearchIcon { background: transparent; }
QLabel#TbSearchPlaceholder {
    color: #6b7587; background: transparent;
    font-family: "Inter", "Helvetica Neue", "Hiragino Sans", "Yu Gothic UI", sans-serif;
    font-size: 12.5px; font-weight: 400;
}
QLabel#TbKbd {
    color: #6b7587;
    background: #ffffff;
    border: 1px solid #e5e8ee;
    border-radius: 4px;
    padding: 1px 5px;
    font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
    font-size: 10.5px; font-weight: 500;
}

QPushButton#TbBtn {
    min-height: 30px;
    padding: 0 10px;
    border: 1px solid #e5e8ee;
    border-radius: 8px;
    background: #ffffff;
    color: #0f172a;
    font-family: "Inter", "Helvetica Neue", "Hiragino Sans", "Yu Gothic UI", sans-serif;
    font-size: 12.5px; font-weight: 500;
}
QPushButton#TbBtn:hover:enabled { background: #eef0f3; }
QPushButton#TbBtn[variant="primary"] {
    background: #14b8a6;
    color: #ffffff;
    border: 1px solid #14b8a6;
    font-weight: 600;
}
QPushButton#TbBtn[variant="primary"]:hover:enabled { background: #0ea597; border-color: #0ea597; }
QPushButton#TbBtn:disabled { color: #94a3b8; background: #f1f3f7; }
QFrame#TbDivider { background: #e5e8ee; border: none; }

/* ---------- StatusBar (grid-embedded) ---------- */
QWidget#StatusBar { background: #ffffff; border-top: 1px solid #e5e8ee; }
QWidget#StatusSeg { background: transparent; }
QLabel#StatusDot { background: #0b8457; border-radius: 3px; }
QLabel#StatusLabel {
    color: #4a5568; background: transparent;
    font-family: "Inter", "Helvetica Neue", "Hiragino Sans", "Yu Gothic UI", sans-serif;
    font-size: 11.5px; font-weight: 500;
}
QWidget#StatusSeg[tone="pos"] QLabel#StatusLabel {
    color: #0b8457;
    font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
}
QWidget#StatusSeg[tone="neg"] QLabel#StatusLabel {
    color: #b5341f;
    font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
}
QPushButton#StatusLogBtn {
    background: #eef0f3;
    color: #4a5568;
    border: 1px solid #e5e8ee;
    border-radius: 6px;
    padding: 0 10px;
    min-height: 22px;
    font-family: "Inter", "Helvetica Neue", "Hiragino Sans", "Yu Gothic UI", sans-serif;
    font-size: 11.5px; font-weight: 500;
}
QPushButton#StatusLogBtn:hover { background: #e6e9ef; }
QPushButton#StatusLogBtn[active="true"] {
    background: #d8efeb;
    color: #064e47;
    border-color: #d8efeb;
}

/* ---------- LogDock (bottom) ---------- */
QDockWidget#LogDock { border-top: 1px solid #e5e8ee; }
QWidget#LogTitleBar { background: #0f172a; }
QLabel#LogTitle {
    color: #d9dee8; background: transparent;
    font-family: "Inter", "Helvetica Neue", "Hiragino Sans", "Yu Gothic UI", sans-serif;
    font-size: 11.5px; font-weight: 600;
    letter-spacing: 0.08em;
}
QToolButton#LogClose {
    color: #d9dee8; background: transparent; border: none;
    font-size: 16px; font-weight: 600;
    padding: 0 8px;
}
QToolButton#LogClose:hover { color: #ffffff; }
QPlainTextEdit#LogView {
    background: #0b1220;
    color: #d9dee8;
    font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
    font-size: 12px; font-weight: 400;
    border: none;
    padding: 10px 14px;
}
